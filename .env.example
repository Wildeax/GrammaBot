# Telegram bot (create one with @BotFather and paste the token here)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Speech-to-text. OpenRouter or any OpenAI-compatible /audio/transcriptions endpoint.
TRANSCRIBE_API_KEY=your-key
TRANSCRIBE_BASE_URL=https://openrouter.ai/api/v1
TRANSCRIBE_MODEL=openai/gpt-4o-mini-transcribe

# LLM for understanding/extraction. Provider-agnostic (OpenAI-compatible endpoint).
LLM_API_KEY=your-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash

# Cheap first-stage guard model (jailbreak / off-topic / abuse). Same provider as LLM.
GUARD_MODEL=google/gemini-2.5-flash-lite
# Set to 1 to disable the guard entirely.
GUARD_DISABLED=

# Behavior
DEFAULT_LANGUAGE=es
DEFAULT_CURRENCY=COP
# Civil timezone for "today"/month boundaries (users are in Colombia).
TIMEZONE=America/Bogota
DATABASE_PATH=./grammabot.sqlite
# Set to 1 to log transcripts and message text (off by default for privacy).
DEBUG=

# Access control: comma-separated Telegram chat IDs allowed to use the bot.
# Empty = DENY everyone (fail-closed). Send /miid to the bot to learn a chat ID.
ALLOWED_CHAT_IDS=
# Explicit opt-in to open the bot to ANYONE (only honored when ALLOWED_CHAT_IDS is empty).
ALLOW_ANYONE=
