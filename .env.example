# Server
PORT=3000

# WhatsApp Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api)
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Speech-to-text (Whisper). Works with OpenAI or any OpenAI-compatible endpoint (e.g. Groq).
TRANSCRIBE_API_KEY=your-key
TRANSCRIBE_BASE_URL=https://api.openai.com/v1
TRANSCRIBE_MODEL=whisper-1

# LLM for understanding/extraction. Provider-agnostic (OpenAI-compatible endpoint).
LLM_API_KEY=your-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Behavior
DEFAULT_LANGUAGE=es
DATABASE_PATH=./grammabot.sqlite
